---
import Layout from "@/layouts/Layout.astro";
import { clubTimeline, clubStats, keyAchievements, didYouKnowFacts } from "@/data/clubHistory";

// Flatten all timeline events in chronological order
const allEvents = [
  ...clubTimeline.founding,
  ...clubTimeline.earlyDevelopment,
  ...clubTimeline.growth,
  ...clubTimeline.currentEra,
];
---

<Layout title="History - progsu">
  <div class="min-h-screen bg-black">

    <!-- Hero -->
    <section class="pt-32 pb-16 px-8">
      <div class="max-w-3xl mx-auto text-center float-in">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 tracking-tight italic" style="font-family: 'Noto Serif', Georgia, serif !important;">
          the story
        </h1>
        <p class="text-base md:text-lg text-white/50 leading-relaxed font-light max-w-2xl mx-auto" style="font-family: 'Helvetica Neue', sans-serif;">
          born in a pandemic. shaped by five presidents. built by hundreds of people who believed code could be culture.
        </p>
      </div>
    </section>

    <!-- Stats -->
    <section class="py-12 px-8">
      <div class="max-w-3xl mx-auto float-in">
        <div class="flex justify-center items-center gap-12 md:gap-20">
          <div class="text-center">
            <div class="text-2xl md:text-3xl font-light text-white mb-1" style="font-family: 'Helvetica Neue', sans-serif;">{clubStats.yearsStrong}</div>
            <div class="text-xs text-white/45 tracking-widest" style="font-family: 'Helvetica Neue', sans-serif;">years</div>
          </div>
          <div class="text-center">
            <div class="text-2xl md:text-3xl font-light text-white mb-1" style="font-family: 'Helvetica Neue', sans-serif;">{clubStats.studentsHelped}</div>
            <div class="text-xs text-white/45 tracking-widest" style="font-family: 'Helvetica Neue', sans-serif;">builders</div>
          </div>
          <div class="text-center">
            <div class="text-2xl md:text-3xl font-light text-white mb-1" style="font-family: 'Helvetica Neue', sans-serif;">5</div>
            <div class="text-xs text-white/45 tracking-widest" style="font-family: 'Helvetica Neue', sans-serif;">presidents</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Timeline -->
    <section class="py-16 px-8">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-12 tracking-widest text-center" style="font-family: 'Helvetica Neue', sans-serif;">
          timeline
        </h2>

        <div class="relative">
          <!-- Vertical line -->
          <div class="absolute left-0 md:left-1/2 top-0 bottom-0 w-px bg-white/10 transform md:-translate-x-px"></div>

          {allEvents.map((event, i) => {
            const isLeft = i % 2 === 0;
            return (
              <div class="relative mb-16 float-in">
                <!-- Dot -->
                <div class:list={[
                  "absolute w-2 h-2 rounded-full top-2 z-10",
                  event.type === "milestone" ? "bg-purple-400" : "bg-white/30",
                  "left-0 md:left-1/2 transform -translate-x-1/2"
                ]} />

                <!-- Content -->
                <div class:list={[
                  "pl-8 md:pl-0 md:w-1/2",
                  isLeft ? "md:pr-12 md:text-right" : "md:pl-12 md:ml-auto",
                ]}>
                  <p class="text-white/40 text-xs tracking-widest mb-2" style="font-family: 'Helvetica Neue', sans-serif;">
                    {event.date.toLowerCase()}
                  </p>
                  <h3 class="text-white font-medium text-base italic mb-2" style="font-family: 'Noto Serif', Georgia, serif !important;">
                    {event.title}
                  </h3>
                  <p class="text-white/40 text-sm leading-relaxed" style="font-family: 'Helvetica Neue', sans-serif;">
                    {event.description}
                  </p>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Achievements -->
    <section class="py-16 px-8">
      <div class="max-w-3xl mx-auto float-in">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-8 tracking-widest text-center" style="font-family: 'Helvetica Neue', sans-serif;">
          milestones
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6 max-w-2xl mx-auto">
          {keyAchievements.map((a) => (
            <div class="text-center md:text-left">
              <h3 class="text-white font-medium text-sm italic" style="font-family: 'Noto Serif', Georgia, serif !important;">
                {a.title.toLowerCase()}
              </h3>
              <p class="text-white/45 text-xs mt-1" style="font-family: 'Helvetica Neue', sans-serif;">
                {a.description.toLowerCase()}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Fun Facts -->
    <section class="py-16 px-8">
      <div class="max-w-2xl mx-auto float-in">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-8 tracking-widest text-center" style="font-family: 'Helvetica Neue', sans-serif;">
          lore
        </h2>
        <div class="space-y-6">
          {didYouKnowFacts.map((fact) => (
            <p class="text-white/50 text-sm leading-relaxed text-center" style="font-family: 'Helvetica Neue', sans-serif;">
              {fact.toLowerCase()}
            </p>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 px-8">
      <div class="max-w-2xl mx-auto text-center float-in">
        <p class="text-white/40 text-sm tracking-widest mb-6" style="font-family: 'Helvetica Neue', sans-serif;">
          the story isn't finished.
        </p>
        <div class="flex justify-center gap-8">
          <a
            href="/members"
            class="text-white/40 hover:text-white text-sm tracking-widest transition-all duration-300"
            style="font-family: 'Helvetica Neue', sans-serif; text-shadow: 0 0 8px rgba(147, 51, 234, 0);"
            onmouseover="this.style.textShadow='0 0 12px rgba(147,51,234,1), 0 0 30px rgba(147,51,234,0.6), 0 0 60px rgba(147,51,234,0.25)'"
            onmouseout="this.style.textShadow='0 0 8px rgba(147,51,234,0)'"
          >
            meet the people
          </a>
        </div>
      </div>
    </section>

    <!-- Back + Footer -->
    <div class="py-8 text-center">
      <a
        href="/"
        class="text-white/45 hover:text-white text-sm tracking-widest transition-all duration-300"
        style="font-family: 'Helvetica Neue', sans-serif; text-shadow: 0 0 8px rgba(147, 51, 234, 0);"
        onmouseover="this.style.textShadow='0 0 12px rgba(147,51,234,1), 0 0 30px rgba(147,51,234,0.6), 0 0 60px rgba(147,51,234,0.25)'"
        onmouseout="this.style.textShadow='0 0 8px rgba(147,51,234,0)'"
      >
        &larr; back to home
      </a>
      <p class="text-white/50 text-xs mt-6 tracking-widest" style="font-family: 'Helvetica Neue', sans-serif;">
        &copy; 2025 progsu
      </p>
    </div>
  </div>
</Layout>

<style>
  .float-in {
    opacity: 0;
    transform: translateY(40px);
    filter: blur(10px);
    transition: opacity 0.9s ease-out, transform 0.9s ease-out, filter 0.9s ease-out;
  }

  .float-in.visible {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }
</style>

<script>
  function initHistory() {
    const elements = document.querySelectorAll('.float-in');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    elements.forEach((el) => observer.observe(el));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHistory);
  } else {
    initHistory();
  }
  document.addEventListener('astro:page-load', initHistory);
</script>
