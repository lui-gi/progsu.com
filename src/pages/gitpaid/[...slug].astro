---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import { SITE_TITLE } from "@/consts";

export async function getStaticPaths() {
  const gitpaidGuides = await getCollection('gitpaid');
  return gitpaidGuides.map(guide => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content, headings } = await guide.render();
const tocHeadings = headings.filter(h => h.depth <= 3);
---

<Layout title={`${guide.data.title} - ${SITE_TITLE}`} staticHeader={true}>
  <div class="min-h-screen bg-black">

    <!-- Article Header -->
    <section class="pt-32 pb-12 px-8">
      <div class="max-w-3xl mx-auto float-in">
        <!-- Breadcrumb -->
        <div class="flex items-center gap-2 mb-8 text-xs tracking-widest" style="font-family: 'Helvetica Neue', sans-serif;">
          <a href="/" class="text-white/45 hover:text-white/60 transition-colors">progsu</a>
          <span class="text-white/15">/</span>
          <a href="/gitpaid" class="text-white/45 hover:text-white/60 transition-colors">gitpaid</a>
          <span class="text-white/15">/</span>
          <span class="text-white/50">{guide.data.title.toLowerCase()}</span>
        </div>

        <h1 class="text-3xl md:text-4xl font-bold text-white mb-4 tracking-tight italic" style="font-family: 'Noto Serif', Georgia, serif !important;">
          {guide.data.title.toLowerCase()}
        </h1>

        {guide.data.description && (
          <p class="text-base text-white/50 leading-relaxed font-light" style="font-family: 'Helvetica Neue', sans-serif;">
            {guide.data.description.toLowerCase()}
          </p>
        )}
      </div>
    </section>

    <!-- TOC + Content -->
    <section class="px-8 pb-24">
      <div class="max-w-3xl mx-auto">

        <!-- Mobile TOC -->
        {tocHeadings.length > 0 && (
          <div class="mb-12 md:hidden">
            <button
              id="toc-toggle"
              class="text-white/45 text-xs tracking-widest mb-4"
              style="font-family: 'Helvetica Neue', sans-serif;"
            >
              table of contents +
            </button>
            <nav id="toc-mobile" class="hidden space-y-2">
              {tocHeadings.map((h) => (
                <a
                  href={`#${h.slug}`}
                  class:list={[
                    "block text-white/45 hover:text-white/60 text-xs tracking-widest transition-colors",
                    h.depth === 3 ? "pl-4" : "",
                  ]}
                  style="font-family: 'Helvetica Neue', sans-serif;"
                >
                  {h.text.toLowerCase()}
                </a>
              ))}
            </nav>
          </div>
        )}

        <!-- Article Content -->
        <article class="gitpaid-prose">
          <Content />
        </article>

        <!-- Back -->
        <div class="mt-16 pt-8 border-t border-white/5">
          <a
            href="/gitpaid"
            class="text-white/45 hover:text-white text-sm tracking-widest transition-all duration-300"
            style="font-family: 'Helvetica Neue', sans-serif; text-shadow: 0 0 8px rgba(147, 51, 234, 0);"
            onmouseover="this.style.textShadow='0 0 12px rgba(147,51,234,1), 0 0 30px rgba(147,51,234,0.6), 0 0 60px rgba(147,51,234,0.25)'"
            onmouseout="this.style.textShadow='0 0 8px rgba(147,51,234,0)'"
          >
            &larr; all guides
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .float-in {
    opacity: 0;
    transform: translateY(40px);
    filter: blur(10px);
    transition: opacity 0.9s ease-out, transform 0.9s ease-out, filter 0.9s ease-out;
  }
  .float-in.visible {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }

  /* Article prose styling for dark theme */
  .gitpaid-prose :global(h1),
  .gitpaid-prose :global(h2),
  .gitpaid-prose :global(h3),
  .gitpaid-prose :global(h4) {
    color: white;
    font-family: 'Noto Serif', Georgia, serif !important;
    font-style: italic;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .gitpaid-prose :global(h2) { font-size: 1.5rem; }
  .gitpaid-prose :global(h3) { font-size: 1.25rem; }

  .gitpaid-prose :global(p) {
    color: rgba(255, 255, 255, 0.72);
    font-family: 'Helvetica Neue', sans-serif;
    line-height: 1.8;
    margin-bottom: 1.25rem;
    font-size: 0.95rem;
  }

  .gitpaid-prose :global(a) {
    color: rgba(168, 85, 247, 0.8);
    text-decoration: underline;
    text-decoration-color: rgba(168, 85, 247, 0.3);
    transition: all 0.2s;
  }

  .gitpaid-prose :global(a:hover) {
    color: rgba(168, 85, 247, 1);
    text-decoration-color: rgba(168, 85, 247, 0.6);
  }

  .gitpaid-prose :global(ul),
  .gitpaid-prose :global(ol) {
    color: rgba(255, 255, 255, 0.68);
    font-family: 'Helvetica Neue', sans-serif;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    font-size: 0.95rem;
    list-style: revert;
  }

  .gitpaid-prose :global(ul) {
    list-style: none;
    padding-left: 1.25rem;
  }

  .gitpaid-prose :global(ol) {
    list-style-type: decimal;
  }

  .gitpaid-prose :global(ul > li) {
    position: relative;
    padding-left: 1rem;
  }

  .gitpaid-prose :global(ul > li::before) {
    content: "•";
    position: absolute;
    left: 0;
    color: rgba(255, 255, 255, 0.55);
  }

  .gitpaid-prose :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }

  /* Task list (self-check) — hide custom bullet */
  .gitpaid-prose :global(li:has(input[type="checkbox"])::before) {
    display: none;
  }
  .gitpaid-prose :global(li:has(input[type="checkbox"])) {
    padding-left: 0;
    color: rgba(255, 255, 255, 0.68);
  }
  .gitpaid-prose :global(ul:has(li > input[type="checkbox"])) {
    padding-left: 0;
  }
  .gitpaid-prose :global(input[type="checkbox"]) {
    appearance: none;
    width: 0.85rem;
    height: 0.85rem;
    border: 1px solid rgba(147, 51, 234, 0.4);
    border-radius: 0.2rem;
    margin-right: 0.5rem;
    vertical-align: middle;
    background: rgba(147, 51, 234, 0.05);
    flex-shrink: 0;
    display: inline-block;
  }

  .gitpaid-prose :global(strong) {
    color: rgba(255, 255, 255, 0.8);
    font-weight: 600;
  }

  .gitpaid-prose :global(code) {
    background: rgba(255, 255, 255, 0.05);
    color: rgba(168, 85, 247, 0.8);
    padding: 0.15rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.85rem;
  }

  .gitpaid-prose :global(pre) {
    background: rgba(147, 51, 234, 0.06) !important;
    border: 1px solid rgba(147, 51, 234, 0.25);
    box-shadow: 0 0 12px rgba(147, 51, 234, 0.08);
    border-radius: 0.5rem;
    padding: 1.25rem;
    margin-bottom: 1.5rem;
    overflow-x: auto;
  }

  .gitpaid-prose :global(pre code) {
    background: none;
    padding: 0;
    color: rgba(255, 255, 255, 0.85);
  }

  .gitpaid-prose :global(blockquote) {
    border-left: 2px solid rgba(147, 51, 234, 0.4);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: rgba(255, 255, 255, 0.6);
    font-style: italic;
  }

  .gitpaid-prose :global(hr) {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: none;
    margin: 2rem 0;
  }

  .gitpaid-prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .gitpaid-prose :global(th) {
    color: rgba(255, 255, 255, 0.6);
    font-weight: 600;
    text-align: left;
    padding: 0.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .gitpaid-prose :global(td) {
    color: rgba(255, 255, 255, 0.62);
    padding: 0.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .gitpaid-prose :global(img) {
    border-radius: 0.5rem;
    margin: 1.5rem 0;
    opacity: 0.9;
  }

  /* Fix button text centering — MDX wraps content in <p> tags */
  .gitpaid-prose :global(a > p),
  .gitpaid-prose :global(button > p) {
    margin: 0;
    padding: 0;
    line-height: inherit;
  }
</style>

<script>
  function init() {
    // Float-in
    const els = document.querySelectorAll('.float-in');
    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
    }, { threshold: 0.15 });
    els.forEach((el) => obs.observe(el));

    // TOC toggle
    const toggle = document.getElementById('toc-toggle');
    const toc = document.getElementById('toc-mobile');
    if (toggle && toc) {
      toggle.addEventListener('click', () => {
        toc.classList.toggle('hidden');
        toggle.textContent = toc.classList.contains('hidden') ? 'table of contents +' : 'table of contents −';
      });
    }
  }
  if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', init); } else { init(); }
  document.addEventListener('astro:page-load', init);
</script>
