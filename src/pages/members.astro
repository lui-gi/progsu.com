---
import Layout from "@/layouts/Layout.astro";
import { membersByYear } from "@/data/members";
import { sortMembersByRole, separateMembersByDisplayType, isPresidentRole, isFoundingPresident } from "@/utils/memberUtils";
import { DISCORD_LINK, GOOGLE_FORM_URL } from "@/consts";

const sortedMembers = sortMembersByRole(membersByYear);
const yearKeys = Object.keys(sortedMembers);
---

<Layout title="Members - progsu">
  <div class="min-h-screen bg-black">

    <!-- Hero -->
    <section class="pt-32 pb-16 px-8">
      <div class="max-w-4xl mx-auto text-center float-in">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 tracking-tight italic" style="font-family: 'Noto Serif', Georgia, serif !important;">
          the people
        </h1>
        <p class="text-base md:text-lg text-white/50 leading-relaxed font-light max-w-2xl mx-auto" style="font-family: 'Helvetica Neue', sans-serif;">
          every era of progsu, shaped by the people who showed up and built something.
        </p>
      </div>
    </section>

    <!-- Year Navigation -->
    <section class="px-8 pb-8">
      <div class="max-w-4xl mx-auto">
        <div class="flex justify-center gap-6 flex-wrap">
          {yearKeys.map((year, i) => (
            <button
              data-year={year}
              class:list={[
                "year-tab text-sm tracking-widest transition-all duration-300 pb-1",
                i === 0
                  ? "text-white border-b border-white/40"
                  : "text-white/45 hover:text-white/60 border-b border-transparent",
              ]}
              style="font-family: 'Helvetica Neue', sans-serif;"
            >
              {year}
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- Members by Year -->
    {yearKeys.map((year, yearIndex) => {
      const members = sortedMembers[year];
      const { fullCardMembers, liteCardMembers, listMembers } = separateMembersByDisplayType(members);
      const allDisplayMembers = [...fullCardMembers, ...liteCardMembers];

      return (
        <section
          data-year-content={year}
          class:list={["year-content px-8 pb-24", yearIndex === 0 ? "" : "hidden"]}
        >
          <div class="max-w-5xl mx-auto float-in">

            {/* Leadership + Core */}
            {allDisplayMembers.length > 0 && (
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-16 mb-20">
                {allDisplayMembers.map((member) => {
                  const isPresident = isPresidentRole(member.role);
                  const isFounding = isFoundingPresident(member.role);
                  const memberData = encodeURIComponent(JSON.stringify(member));
                  return (
                    <button
                      class="text-center space-y-3 cursor-pointer group/member focus:outline-none focus-visible:outline-none outline-none transition-all duration-300 hover:-translate-y-1 active:scale-95"
                      data-member={memberData}
                      onclick="openMemberModal(this)"
                    >
                      {/* Initials circle */}
                      <div class:list={[
                        "w-16 h-16 rounded-full mx-auto flex items-center justify-center text-lg font-bold transition-all duration-300 group-hover/member:scale-110 group-hover/member:shadow-lg",
                        isFounding
                          ? "bg-purple-500/20 text-purple-300 group-hover/member:bg-purple-500/40 group-hover/member:shadow-purple-500/30"
                          : isPresident
                            ? "bg-amber-500/20 text-amber-300 group-hover/member:bg-amber-500/40 group-hover/member:shadow-amber-500/30"
                            : "bg-white/5 text-white/60 group-hover/member:bg-white/15 group-hover/member:shadow-white/10",
                      ]}>
                        {member.name.split(" ").map((n: string) => n[0]).join("")}
                      </div>

                      <div>
                        <h3 class="text-white font-medium text-base italic transition-colors duration-300" style="font-family: 'Noto Serif', Georgia, serif !important;">
                          {member.name}
                        </h3>
                        <p class:list={[
                          "text-xs tracking-widest mt-1 transition-all duration-300",
                          isFounding
                            ? "text-purple-400/70 group-hover/member:text-purple-400"
                            : isPresident
                              ? "text-amber-400/70 group-hover/member:text-amber-400"
                              : "text-white/45 group-hover/member:text-white/50",
                        ]} style="font-family: 'Helvetica Neue', sans-serif;">
                          {member.role.toLowerCase()}{member.team ? ` · ${member.team.toLowerCase()}` : ""}
                        </p>
                      </div>

                      {member.specialties && member.specialties.length > 0 && (
                        <div class="flex flex-wrap justify-center gap-2">
                          {member.specialties.slice(0, 3).map((s: string) => (
                            <span class="text-white/50 text-xs" style="font-family: 'Helvetica Neue', sans-serif;">
                              {s.toLowerCase()}
                            </span>
                          ))}
                        </div>
                      )}

                      {(member.github || member.linkedin) && (
                        <div class="flex justify-center gap-4 pt-1" onclick="event.stopPropagation()">
                          {member.github && (
                            <a
                              href={`https://github.com/${member.github}`}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="text-white/50 hover:text-white/60 text-xs tracking-widest transition-all duration-300"
                              style="font-family: 'Helvetica Neue', sans-serif;"
                            >
                              github
                            </a>
                          )}
                          {member.linkedin && (
                            <a
                              href={member.linkedin.startsWith("http") ? member.linkedin : `https://linkedin.com/in/${member.linkedin}`}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="text-white/50 hover:text-white/60 text-xs tracking-widest transition-all duration-300"
                              style="font-family: 'Helvetica Neue', sans-serif;"
                            >
                              linkedin
                            </a>
                          )}
                        </div>
                      )}
                    </button>
                  );
                })}
              </div>
            )}

            {/* General Members */}
            {listMembers.length > 0 && (
              <div>
                <p class="text-white/50 text-xs tracking-[0.3em] uppercase text-center mb-8" style="font-family: 'Helvetica Neue', sans-serif;">
                  members
                </p>
                <div class="flex flex-wrap justify-center gap-x-8 gap-y-3 max-w-3xl mx-auto">
                  {listMembers.map((member) => (
                    <span class="text-white/40 text-sm" style="font-family: 'Helvetica Neue', sans-serif;">
                      {member.name.toLowerCase()}
                    </span>
                  ))}
                </div>
              </div>
            )}
          </div>
        </section>
      );
    })}

    <!-- Member Modal -->
    <div
      id="member-modal"
      class="fixed inset-0 z-50 flex items-center justify-center p-4 pointer-events-none opacity-0 transition-opacity duration-300"
      onclick="if(event.target===this)closeMemberModal()"
    >
      <!-- Backdrop -->
      <div class="absolute inset-0 bg-black/80 backdrop-blur-sm"></div>
      <!-- Card -->
      <div id="member-modal-card" class="relative z-10 w-full max-w-sm bg-black border border-white/10 rounded-2xl p-8 shadow-2xl transition-all duration-300 scale-95 opacity-0 translate-y-2">
        <button
          onclick="closeMemberModal()"
          class="absolute top-4 right-4 text-white/45 hover:text-white transition-colors duration-200 text-lg leading-none"
        >✕</button>

        <!-- Initials -->
        <div id="modal-initials" class="w-16 h-16 rounded-full flex items-center justify-center text-xl font-bold mb-5 bg-white/5 text-white/60"></div>

        <!-- Name + Role -->
        <h2 id="modal-name" class="text-xl font-bold text-white italic mb-1" style="font-family: 'Noto Serif', Georgia, serif !important;"></h2>
        <p id="modal-role" class="text-xs tracking-widest text-white/45 mb-1" style="font-family: 'Helvetica Neue', sans-serif;"></p>
        <p id="modal-major" class="text-xs text-white/50 mb-5" style="font-family: 'Helvetica Neue', sans-serif;"></p>

        <!-- Description -->
        <p id="modal-description" class="text-sm text-white/50 leading-relaxed mb-6" style="font-family: 'Helvetica Neue', sans-serif;"></p>

        <!-- Specialties -->
        <div id="modal-specialties-wrap" class="mb-6 hidden">
          <p class="text-[10px] uppercase tracking-widest text-white/50 mb-3" style="font-family: 'Helvetica Neue', sans-serif;">specialties</p>
          <div id="modal-specialties" class="flex flex-wrap gap-2"></div>
        </div>

        <!-- Social links -->
        <div id="modal-socials" class="flex gap-3"></div>
      </div>
    </div>

    <!-- Join CTA -->
    <section class="py-16 px-8">
      <div class="max-w-2xl mx-auto text-center float-in">
        <p class="text-white/40 text-sm tracking-widest mb-6" style="font-family: 'Helvetica Neue', sans-serif;">
          want to be on this page?
        </p>
        <div class="flex justify-center gap-8">
          <a
            href={GOOGLE_FORM_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="text-white/40 hover:text-white text-sm tracking-widest transition-all duration-300"
            style="font-family: 'Helvetica Neue', sans-serif; text-shadow: 0 0 8px rgba(147, 51, 234, 0);"
            onmouseover="this.style.textShadow='0 0 12px rgba(147,51,234,1), 0 0 30px rgba(147,51,234,0.6), 0 0 60px rgba(147,51,234,0.25)'"
            onmouseout="this.style.textShadow='0 0 8px rgba(147,51,234,0)'"
          >
            join progsu
          </a>
          <a
            href={DISCORD_LINK}
            target="_blank"
            rel="noopener noreferrer"
            class="text-white/40 hover:text-white text-sm tracking-widest transition-all duration-300"
            style="font-family: 'Helvetica Neue', sans-serif; text-shadow: 0 0 8px rgba(147, 51, 234, 0);"
            onmouseover="this.style.textShadow='0 0 12px rgba(147,51,234,1), 0 0 30px rgba(147,51,234,0.6), 0 0 60px rgba(147,51,234,0.25)'"
            onmouseout="this.style.textShadow='0 0 8px rgba(147,51,234,0)'"
          >
            discord
          </a>
        </div>
      </div>
    </section>

    <!-- Back + Footer -->
    <div class="py-8 text-center">
      <a
        href="/"
        class="text-white/45 hover:text-white text-sm tracking-widest transition-all duration-300"
        style="font-family: 'Helvetica Neue', sans-serif; text-shadow: 0 0 8px rgba(147, 51, 234, 0);"
        onmouseover="this.style.textShadow='0 0 12px rgba(147,51,234,1), 0 0 30px rgba(147,51,234,0.6), 0 0 60px rgba(147,51,234,0.25)'"
        onmouseout="this.style.textShadow='0 0 8px rgba(147,51,234,0)'"
      >
        &larr; back to home
      </a>
      <p class="text-white/50 text-xs mt-6 tracking-widest" style="font-family: 'Helvetica Neue', sans-serif;">
        &copy; 2025 progsu
      </p>
    </div>
  </div>
</Layout>

<style>
  .float-in {
    opacity: 0;
    transform: translateY(40px);
    filter: blur(10px);
    transition: opacity 0.9s ease-out, transform 0.9s ease-out, filter 0.9s ease-out;
  }

  .float-in.visible {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }
</style>

<script>
  function initMembers() {
    // Float-in animation
    const floatEls = document.querySelectorAll('.float-in');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    floatEls.forEach((el) => observer.observe(el));

    // Year tab switching
    const tabs = document.querySelectorAll('.year-tab');
    const contents = document.querySelectorAll('.year-content');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const year = (tab as HTMLElement).dataset.year;

        // Update tab styles
        tabs.forEach((t) => {
          t.classList.remove('text-white', 'border-white/40');
          t.classList.add('text-white/45', 'border-transparent');
        });
        tab.classList.remove('text-white/45', 'border-transparent');
        tab.classList.add('text-white', 'border-white/40');

        // Show/hide content
        contents.forEach((c) => {
          const el = c as HTMLElement;
          if (el.dataset.yearContent === year) {
            el.classList.remove('hidden');
            // Re-trigger float-in
            const floatIn = el.querySelector('.float-in');
            if (floatIn) {
              floatIn.classList.remove('visible');
              requestAnimationFrame(() => {
                floatIn.classList.add('visible');
              });
            }
          } else {
            el.classList.add('hidden');
          }
        });
      });
    });

    // Purple glow on year tabs hover
    tabs.forEach((tab) => {
      const el = tab as HTMLElement;
      el.addEventListener('mouseover', () => {
        el.style.textShadow = '0 0 12px rgba(147,51,234,1), 0 0 30px rgba(147,51,234,0.6), 0 0 60px rgba(147,51,234,0.25)';
      });
      el.addEventListener('mouseout', () => {
        el.style.textShadow = '0 0 8px rgba(147,51,234,0)';
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMembers);
  } else {
    initMembers();
  }
  document.addEventListener('astro:page-load', initMembers);

  function openMemberModal(btn: HTMLElement) {
    const raw = btn.getAttribute('data-member');
    if (!raw) return;
    const member = JSON.parse(decodeURIComponent(raw));

    const modal = document.getElementById('member-modal')!;
    const card = document.getElementById('member-modal-card')!;

    // Initials
    const initials = member.name.split(' ').map((n: string) => n[0]).join('');
    document.getElementById('modal-initials')!.textContent = initials;

    // Name / role / major
    document.getElementById('modal-name')!.textContent = member.name;
    const roleEl = document.getElementById('modal-role')!;
    roleEl.textContent = member.role.toLowerCase() + (member.team ? ` · ${member.team.toLowerCase()}` : '');
    const majorEl = document.getElementById('modal-major')!;
    majorEl.textContent = member.major ? member.major : '';
    majorEl.style.display = member.major ? '' : 'none';

    // Description
    document.getElementById('modal-description')!.textContent = member.description || '';

    // Specialties
    const specWrap = document.getElementById('modal-specialties-wrap')!;
    const specContainer = document.getElementById('modal-specialties')!;
    specContainer.innerHTML = '';
    if (member.specialties && member.specialties.length > 0) {
      member.specialties.forEach((s: string) => {
        const span = document.createElement('span');
        span.textContent = s.toLowerCase();
        span.className = 'px-2 py-1 text-xs rounded-full border border-white/10 text-white/40 bg-white/5';
        span.style.fontFamily = "'Helvetica Neue', sans-serif";
        specContainer.appendChild(span);
      });
      specWrap.classList.remove('hidden');
    } else {
      specWrap.classList.add('hidden');
    }

    // Socials
    const socials = document.getElementById('modal-socials')!;
    socials.innerHTML = '';
    if (member.github) {
      const a = document.createElement('a');
      a.href = `https://github.com/${member.github}`;
      a.target = '_blank';
      a.rel = 'noopener noreferrer';
      a.textContent = 'github';
      a.className = 'text-white/45 hover:text-white text-xs tracking-widest transition-all duration-300';
      a.style.fontFamily = "'Helvetica Neue', sans-serif";
      socials.appendChild(a);
    }
    if (member.linkedin) {
      const a = document.createElement('a');
      const href = member.linkedin.startsWith('http') ? member.linkedin : `https://linkedin.com/in/${member.linkedin}`;
      a.href = href;
      a.target = '_blank';
      a.rel = 'noopener noreferrer';
      a.textContent = 'linkedin';
      a.className = 'text-white/45 hover:text-white text-xs tracking-widest transition-all duration-300';
      a.style.fontFamily = "'Helvetica Neue', sans-serif";
      socials.appendChild(a);
    }

    modal.classList.remove('pointer-events-none');
    modal.classList.add('pointer-events-auto');
    requestAnimationFrame(() => {
      modal.classList.remove('opacity-0');
      modal.classList.add('opacity-100');
      card.classList.remove('scale-95', 'opacity-0', 'translate-y-2');
      card.classList.add('scale-100', 'opacity-100', 'translate-y-0');
    });
    document.body.style.overflow = 'hidden';
  }

  function closeMemberModal() {
    const modal = document.getElementById('member-modal')!;
    const card = document.getElementById('member-modal-card')!;
    modal.classList.remove('opacity-100');
    modal.classList.add('opacity-0');
    card.classList.remove('scale-100', 'opacity-100', 'translate-y-0');
    card.classList.add('scale-95', 'opacity-0', 'translate-y-2');
    setTimeout(() => {
      modal.classList.remove('pointer-events-auto');
      modal.classList.add('pointer-events-none');
    }, 300);
    document.body.style.overflow = '';
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMemberModal();
  });

  (window as any).openMemberModal = openMemberModal;
  (window as any).closeMemberModal = closeMemberModal;
</script>
